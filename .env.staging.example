NODE_ENV=production
PORT=5000
CORS_ORIGIN=https://staging.quickturf.example
DATABASE_URL=postgresql://USER:PASSWORD@HOST/STAGING_DB?sslmode=require
SESSION_SECRET=replace-with-a-long-random-staging-secret
ADMIN_KEY=replace-with-a-staging-admin-key
CLOUDINARY_CLOUD_NAME=replace-with-staging-cloudinary-cloud
CLOUDINARY_UPLOAD_PRESET=replace-with-staging-upload-preset
OPENROUTESERVICE_API_KEY=optional-free-openrouteservice-key-for-travel-estimates
# ORS_API_KEY is also supported as a shorter alias.

# Google Sign-In
GOOGLE_CLIENT_ID=your-google-oauth-web-client-id.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=your-google-oauth-web-client-id.apps.googleusercontent.com
